{
  "name": "skribbl-clone",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @skribbl/shared --filter web --filter server dev",
    "build": "pnpm --filter @skribbl/shared build && pnpm --filter web build && pnpm --filter server build",
    "db:push": "pnpm --filter server db:push",
    "db:generate": "pnpm --filter server db:generate",
    "db:studio": "pnpm --filter server db:studio"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}